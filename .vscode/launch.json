      "gdbPath": "/usr/local/bin/arm-none-eabi-gdb",
      "preLaunchTask": "GDB server: start",
      "showDevDebugOutput": "none"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "lldb",
