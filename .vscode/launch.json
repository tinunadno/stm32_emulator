{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "STM32: Debug без ELF (Cortex-Debug)",
      "type": "cortex-debug",
      "request": "attach",
      "servertype": "external",
      "gdbTarget": "localhost:3333",
      "executable": "${workspaceFolder}/examples/stub.elf",
      "gdbPath": "/usr/local/bin/arm-none-eabi-gdb",
      "preLaunchTask": "GDB server: start",
      "showDevDebugOutput": "none"
    },
    {
      "name": "STM32: Debug с ELF (Cortex-Debug)",
